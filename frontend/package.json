{
  "name": "smart-mall-crm-frontend",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "export-pdf": "npx markdown-pdf PROJECT_OVERVIEW.md -o Project_Overview.pdf",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist node_modules package-lock.json",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:prod": "npm run build && firebase deploy --only hosting:production",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles",
    "test:emulator": "firebase emulators:exec --only firestore \"npm test\"",
    "emulators": "firebase emulators:start --only firestore",
    "firebase:init": "firebase init hosting",
    "firebase:login": "firebase login",
    "predeploy": "npm run build",
    "postbuild": "echo '/*    /index.html   200' > dist/_redirects"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^10.7.1",
    "framer-motion": "^12.29.0",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-chained-backend": "^5.0.2",
    "i18next-http-backend": "^3.0.2",
    "i18next-localstorage-backend": "^4.3.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.473.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.3",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.3",
    "recharts": "^2.10.3",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.11"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
