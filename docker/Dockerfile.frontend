# المرحلة 1: بناء التطبيق
FROM node:18-alpine AS build

WORKDIR /app

# نسخ ملفات package
COPY package*.json ./

# تثبيت المكتبات
RUN npm install

# نسخ الكود
COPY . .

# بناء التطبيق
RUN npm run build

# المرحلة 2: خادم الإنتاج
FROM nginx:alpine

# نسخ الملفات المبنية
COPY --from=build /app/dist /usr/share/nginx/html

# نسخ إعدادات Nginx
COPY nginx.conf /etc/nginx/conf.d/default.conf

# فتح المنفذ
EXPOSE 80

# تشغيل Nginx
CMD ["nginx", "-g", "daemon off;"]
