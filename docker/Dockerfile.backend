# Dockerfile.backend مبسط وجاهز للشغل
FROM python:3.11-bullseye

# إعداد مجلد العمل
WORKDIR /app

# نسخ ملفات المشروع
COPY . .

# تحديث pip وتثبيت المتطلبات
RUN pip install --upgrade pip setuptools wheel \
    && pip install --no-cache-dir -r requirements.txt

# تحديد المنفذ اللي هيتواصل عليه backend
EXPOSE 5000

# أمر التشغيل الرئيسي للـ backend
CMD ["python", "app.py"]

